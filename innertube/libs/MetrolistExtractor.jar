</nav>

<div class="jumbotron" id="headerwrap">
    <div class="container">
        <h1>
            <a href="/">JitPack</a>
        </h1>
        <h3>Easy to use package repository for Git</h3>
        <p>Publish your JVM and Android libraries</p>
    </div>
</div>


<div class="container space">

    <div class="row"></div>

    <div class="row">
        <div class="col-lg-12">
            <h1 class="page-header" id="buttons"></h1>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 col-lg-offset-2">
            <h2 id="1-terms">Connection</h2>
            <p>There seems to be an issue connecting to our servers. Please try again in a few minutes.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 col-lg-offset-2"></div>
        <p></p>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <h1 class="page-header"></h1>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 col-lg-offset-2">
            <p>For any questions please get in touch.</p>
        </div>
    </div>

</div>

