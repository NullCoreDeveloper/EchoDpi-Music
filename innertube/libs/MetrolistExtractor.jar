    <meta name="description" content="JitPack makes it easy to release your GitHub projects.
	We build Gradle/Maven/Android projects on demand and publish artifacts." />
    <meta name="keywords" content="jitpack,maven,android,gradle,package,repository,publish,maven central,maven repository,maven publish,maven release,maven artifact,maven package,maven hosting,gradle hosting,easy maven central,simple,gradle repository,sbt,leiningen,clojure,scala,aar,jar" />


</head>

